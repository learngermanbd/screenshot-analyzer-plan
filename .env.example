# Environment Variables
# Copy this file to .env.local and fill in your values
# See setup-guide.html for detailed instructions

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- Cloudflare R2 Storage ---
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=screenshot-analyzer-images

# --- Upstash Redis (Optional) ---
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# --- Hugging Face ML Service ---
ML_SERVICE_URL=https://your-username-screenshot-analyzer-ml.hf.space

# --- Sentry Error Monitoring (Optional) ---
# Get your DSN from https://sentry.io -> Settings -> Client Keys (DSN)
SENTRY_DSN=https://your-dsn@sentry.io/project-id
# Set these in CI/Vercel environment for source map uploads (do NOT commit these)
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# --- Umami Analytics (Optional) ---
# Self-hosted: set NEXT_PUBLIC_UMAMI_SCRIPT_URL to your Umami instance
# Umami Cloud: just set the website ID from your Umami dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# --- REST API (Optional) ---
# Set this to protect your public API endpoints with Bearer token auth
# Leave empty to allow unauthenticated access (not recommended for production)
API_SECRET_KEY=your-api-secret-key

# --- NextAuth ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
