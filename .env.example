# ═══════════════════════════════════════════════════════════════
# Environment Variables — Template
# 
# Copy this file to .env.local and fill in your values.
# See SETUP.md for detailed step-by-step instructions.
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (Database + API) ─────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API + Database

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pooler connection (PgBouncer port 6543) — use for Next.js serverless
# Get from: Supabase Dashboard → Database → Connection String → Session Pooler
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASS@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (port 5432) — for Prisma migrations locally
DIRECT_URL=postgresql://postgres:YOUR_DB_PASS@db.YOUR_REF.supabase.co:5432/postgres

# ─── Google Gemini AI (Code Generation) ──────────────────────────
# Get from: https://aistudio.google.com/apikey
# Format: AIzaSy... (not OAuth tokens)
GEMINI_API_KEY=your-gemini-api-key

# ─── Cloudflare R2 (Image Storage) ─────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=screenshot-analyzer-images

# ─── Upstash Redis (Caching + Rate Limiting) ───────────────────
# Get from: Upstash Console → Your Database → Details
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Hugging Face ML Service (Optional) ────────────────────────
# Deploy at Hugging Face Spaces; without this, analysis uses mock data.
ML_SERVICE_URL=https://your-username-screenshot-analyzer-ml.hf.space

# ─── Sentry Error Monitoring (Optional) ────────────────────────
# Get from: Sentry → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=https://your-dsn@o0000000.ingest.us.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o0000000.ingest.us.sentry.io/0000000

# For source map uploads during build (set in CI/Vercel):
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# ─── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─── Umami Analytics (Optional) ────────────────────────────────
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.umami.is/script.js

# ─── REST API Security (Optional) ─────────────────────────────
# API_SECRET_KEY=generate-a-strong-random-key-here
