# ═══════════════════════════════════════════════════════════════
# Vercel Environment Variables — Template
# Paste into: Vercel Dashboard → Your Project → Settings → Environment Variables
# 
# Fill in each value below from your credentials file.
# All values are already set in your local .env.local for reference.
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (Database + API) ─────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Pooler (PgBouncer) — REQUIRED for Vercel serverless functions
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String → Session Pooler
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_DB_PASS@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection — for Prisma migrations (run locally)
DIRECT_URL=postgresql://postgres:YOUR_DB_PASS@db.YOUR_REF.supabase.co:5432/postgres

# ─── Google Gemini AI (Code Generation) ──────────────────────────
# Get from: https://aistudio.google.com/apikey
# Format: AIzaSy... (NOT OAuth tokens)

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ─── Cloudflare R2 (Image Storage) ─────────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage API Tokens

R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY

R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY

R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

R2_BUCKET_NAME=screenshot-analyzer-images

# ─── Upstash Redis (Caching + Rate Limiting) ───────────────────
# Get from: Upstash Console → Your Database → Details

UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io

UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ─── Sentry Error Monitoring ───────────────────────────────────
# Get from: Sentry → Settings → Projects → Client Keys (DSN)

SENTRY_DSN=https://YOUR_DSN@o0000000.ingest.us.sentry.io/0000000

NEXT_PUBLIC_SENTRY_DSN=https://YOUR_DSN@o0000000.ingest.us.sentry.io/0000000

# For source map uploads during Vercel build:
# Get from: Sentry → Settings → Developer Settings → Auth Tokens
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# ─── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32

NEXTAUTH_SECRET=YOUR_GENERATED_BASE64_SECRET

# Set to your Vercel deployment URL after first deploy:
NEXTAUTH_URL=https://your-project.vercel.app

# ─── Hugging Face ML Service ───────────────────────────────────
# Deploy at Hugging Face Spaces first, then paste URL here.
# Without this, screenshot analysis falls back to mock data.

ML_SERVICE_URL=https://your-username-screenshot-analyzer-ml.hf.space

# ─── API Security (Optional) ───────────────────────────────────
# API_SECRET_KEY=your-strong-random-key-here
